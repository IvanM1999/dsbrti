  "tabela_smd_codigo_3_digitos": {
    "descricao": "Resistores SMD com código de 3 dígitos (série E24). Os dois primeiros dígitos são os algarismos significativos, o terceiro é o multiplicador (potência de 10).",
    "exemplo": "\"472\" = 47 × 10² = 4700 Ω = 4.7 kΩ",
    "observacao": "Quando o valor é menor que 10 Ω, usa-se 'R' como separador decimal. Ex: '4R7' = 4.7 Ω.",
    "nota": "Valor 0 = jumper (0 Ω, resistência próxima de zero)."
  },

  "tabela_smd_codigo_4_digitos": {
    "descricao": "Resistores SMD de precisão (séries E96/E192) com código de 4 dígitos.",
    "exemplo": "\"4702\" = 470 × 10² = 47000 Ω = 47 kΩ",
    "observacao": "Valores abaixo de 100 Ω usam 'R': '47R0' = 47 Ω."
  },

  "tabela_smd_eia96": {
    "descricao": "Código EIA-96 para resistores SMD ±1%. Usa 2 dígitos (01 a 96) + 1 letra (multiplicador) para codificar valores E96.",
    "exemplo": "\"01D\" = 100 × 1000 = 100 kΩ ±1%",
    "codigos_referencia": "01=100, 02=102, 03=105, ..., 96=976. Letras: A=1, B=10, C=100, D=1000, E=10000, F=100000"
  },

  "leis_e_formulas": {
    "lei_de_ohm": {
      "nome": "Lei de Ohm",
      "formula": "V = R × I",
      "descricao": "Tensão (V) = Resistência (Ω) × Corrente (A). Relação fundamental entre tensão, corrente e resistência.",
      "variacoes": [
        { "encontrar": "Resistência", "formula": "R = V / I" },
        { "encontrar": "Corrente", "formula": "I = V / R" },
        { "encontrar": "Tensão", "formula": "V = R × I" }
      ]
    },
    "potencia": {
      "nome": "Lei da Potência Elétrica / Dissipação Térmica",
      "formula": "P = V × I = V² / R = R × I²",
      "descricao": "Potência dissipada pelo resistor em watts. Essencial para dimensionar a potência nominal do componente.",
      "exemplos": [
        { "descricao": "Resistor 100 Ω com 0.1A", "potencia": "P = 100 × 0.1² = 1W" },
        { "descricao": "Resistor 220 Ω com 12V", "potencia": "P = 12² / 220 = 0.65W (recomendado 1W)" }
      ]
    },
    "associacao_serie": {
      "nome": "Associação em Série",
      "formula": "R_total = R₁ + R₂ + R₃ + ... + Rₙ",
      "descricao": "Resistores conectados em sequência. A resistência total é a soma de todas as resistências."
    },
    "associacao_paralelo": {
      "nome": "Associação em Paralelo",
      "formula": "1/R_total = 1/R₁ + 1/R₂ + 1/R₃ + ... + 1/Rₙ",
      "descricao": "Resistores conectados em ramos paralelos. A resistência total é sempre menor que a menor resistência individual.",
      "caso_especial_dois": "R_total = (R₁ × R₂) / (R₁ + R₂)"
    },
    "divisor_tensao": {
      "nome": "Divisor de Tensão (Pull-Up/Pull-Down)",
      "formula": "V_out = V_in × R₂ / (R₁ + R₂)",
      "descricao": "Circuito clássico com dois resistores para obter uma tensão fracionada da tensão de entrada."
    }
  },

